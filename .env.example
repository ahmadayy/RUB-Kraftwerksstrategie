# Optional API tokens. The DEFAULT data source is Energy-Charts, which needs
# NO token, so you can ignore this file entirely and the model will still run.
#
# Only needed if you switch data_loader.py to the ENTSO-E / renewables.ninja
# path (SOURCE = "entsoe"). To use it:
#   1. copy this file to ".env"   (exact name, with the leading dot)
#   2. paste your tokens after the "=" signs
#   3. NEVER commit ".env" to git -- it is in .gitignore
#
# Tokens are read by data_loader.py via python-dotenv and are never printed.

ENTSOE_API_TOKEN=your-entsoe-token-here
RENEWABLES_NINJA_TOKEN=your-renewables-ninja-token-here
